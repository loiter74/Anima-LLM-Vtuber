# 本地 LoRA 微调模型配置（跨环境模板）
# Local Lora LLM Configuration (Cross-platform Template)

llm_config:
  type: local_lora

  # 模型配置 - 使用环境变量实现跨平台兼容
  base_model_name: "${ANIMA_BASE_MODEL_PATH}"  # 从环境变量读取
  lora_path: "${ANIMA_LORA_PATH}"              # 从环境变量读取
  device: cuda                                  # 计算设备 (cuda/cpu)

  # 生成参数
  max_new_tokens: 512                           # 最大生成 token 数
  temperature: 0.8                              # 温度参数 (0.0-1.0)
  top_p: 0.9                                    # Top-p 采样参数 (0.0-1.0)

# ============================================
# 环境变量设置指南
# ============================================
#
# Windows 环境 (.env 文件):
#   ANIMA_DATA_DIR=E:/anima_data
#   ANIMA_BASE_MODEL_PATH=E:/anima_data/models/base_models/Qwen1.5-1.8B-Chat
#   ANIMA_LORA_PATH=E:/anima_data/models/checkpoints/neuro-vtuber-v1_20260303_220018
#
# WSL 环境 (.env.wsl 文件):
#   ANIMA_DATA_DIR=/mnt/e/anima_data
#   ANIMA_BASE_MODEL_PATH=/mnt/e/anima_data/models/base_models/Qwen1.5-1.8B-Chat
#   ANIMA_LORA_PATH=/mnt/e/anima_data/models/checkpoints/neuro-vtuber-v1_20260303_220018
#
# 纯 Linux 环境 (.env.linux 文件):
#   ANIMA_DATA_DIR=~/anima_data
#   ANIMA_BASE_MODEL_PATH=~/anima_data/models/base_models/Qwen1.5-1.8B-Chat
#   ANIMA_LORA_PATH=~/anima_data/models/checkpoints/neuro-vtuber-v1_20260303_220018
#
# ============================================
