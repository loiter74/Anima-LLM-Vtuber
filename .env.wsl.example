# WSL/Linux 环境配置文件示例
# 复制此文件为 .env.wsl 并修改路径

# 模型存储根目录（WSL 环境）
ANIMA_DATA_DIR=/mnt/e/anima_data

# 或者使用 Linux 本地路径（如果模型在 Linux 文件系统中）
# ANIMA_DATA_DIR=~/anima_data

# 基座模型路径
ANIMA_BASE_MODEL_PATH=${ANIMA_DATA_DIR}/models/base_models/Qwen1.5-1.8B-Chat

# LoRA 模型路径
ANIMA_LORA_PATH=${ANIMA_DATA_DIR}/models/checkpoints/neuro-vtuber-v1_20260303_220018

# 向量数据库路径（Layer 2 RAG）
ANIMA_VECTOR_DB_PATH=${ANIMA_DATA_DIR}/vectordb

# 对话历史存储路径
ANIMA_HISTORY_PATH=${ANIMA_DATA_DIR}/histories
